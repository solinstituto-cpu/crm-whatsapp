{
  "info": {
    "name": "WhatsApp CRM API",
    "description": "Coleção de testes para a API do WhatsApp CRM",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{JWT_TOKEN}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "API_URL",
      "value": "http://localhost:4000/api",
      "type": "string"
    },
    {
      "key": "TEST_PHONE",
      "value": "+5511999999999",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@crm.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{API_URL}}/auth/login",
              "host": ["{{API_URL}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{API_URL}}/auth/profile",
              "host": ["{{API_URL}}"],
              "path": ["auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "WhatsApp",
      "item": [
        {
          "name": "Verify Webhook",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{API_URL}}/wa/webhook?hub.mode=subscribe&hub.verify_token=uma-string-secreta&hub.challenge=test123",
              "host": ["{{API_URL}}"],
              "path": ["wa", "webhook"],
              "query": [
                {
                  "key": "hub.mode",
                  "value": "subscribe"
                },
                {
                  "key": "hub.verify_token",
                  "value": "uma-string-secreta"
                },
                {
                  "key": "hub.challenge",
                  "value": "test123"
                }
              ]
            }
          }
        },
        {
          "name": "Send Text Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to\": \"{{TEST_PHONE}}\",\n  \"type\": \"text\",\n  \"text\": \"Olá! Esta é uma mensagem de teste do CRM.\"\n}"
            },
            "url": {
              "raw": "{{API_URL}}/wa/send",
              "host": ["{{API_URL}}"],
              "path": ["wa", "send"]
            }
          }
        },
        {
          "name": "Send Template",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to\": \"{{TEST_PHONE}}\",\n  \"templateName\": \"welcome_template\",\n  \"language\": \"pt_BR\",\n  \"components\": [\n    {\n      \"type\": \"body\",\n      \"parameters\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"João\"\n        }\n      ]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{API_URL}}/wa/send-template",
              "host": ["{{API_URL}}"],
              "path": ["wa", "send-template"]
            }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{API_URL}}/wa/health",
              "host": ["{{API_URL}}"],
              "path": ["wa", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "Contacts",
      "item": [
        {
          "name": "List Contacts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{API_URL}}/contacts",
              "host": ["{{API_URL}}"],
              "path": ["contacts"]
            }
          }
        },
        {
          "name": "Create Contact",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teste API\",\n  \"phoneE164\": \"{{TEST_PHONE}}\",\n  \"tags\": [\"api\", \"teste\"]\n}"
            },
            "url": {
              "raw": "{{API_URL}}/contacts",
              "host": ["{{API_URL}}"],
              "path": ["contacts"]
            }
          }
        },
        {
          "name": "Get Contact",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{API_URL}}/contacts/{{CONTACT_ID}}",
              "host": ["{{API_URL}}"],
              "path": ["contacts", "{{CONTACT_ID}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "List Conversations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{API_URL}}/conversations",
              "host": ["{{API_URL}}"],
              "path": ["conversations"]
            }
          }
        },
        {
          "name": "Get Conversation",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{API_URL}}/conversations/{{CONVERSATION_ID}}",
              "host": ["{{API_URL}}"],
              "path": ["conversations", "{{CONVERSATION_ID}}"]
            }
          }
        }
      ]
    }
  ]
}