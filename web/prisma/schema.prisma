// Schema para NextAuth - mesmo schema da API
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AGENT
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum MessageDirection {
  IN
  OUT
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  LOCATION
  CONTACT
  STICKER
  SYSTEM
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedContacts Contact[]
  conversations   Conversation[]
  messages        Message[]
  deals           Deal[]

  @@map("users")
}

model Contact {
  id             String    @id @default(cuid())
  name           String
  phoneE164      String    @unique
  tags           String[]
  lastMessageAt  DateTime?
  optOut         Boolean   @default(false)
  optOutAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  assignedToId   String?

  assignedTo     User?           @relation(fields: [assignedToId], references: [id])
  conversations  Conversation[]
  deals          Deal[]

  @@map("contacts")
}

model Conversation {
  id            String             @id @default(cuid())
  contactId     String
  status        ConversationStatus  @default(OPEN)
  lastWAStatus  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  assignedToId  String?

  contact       Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo    User?    @relation(fields: [assignedToId], references: [id])
  messages      Message[]

  @@map("conversations")
}

model Message {
  id             String         @id @default(cuid())
  conversationId String
  direction      MessageDirection
  type           MessageType
  body           String?
  json           Json?
  waMessageId    String?
  status         MessageStatus  @default(PENDING)
  createdAt      DateTime       @default(now())
  sentById       String?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentBy         User?         @relation(fields: [sentById], references: [id])

  @@map("messages")
}

model PipelineStage {
  id        String   @id @default(cuid())
  name      String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals Deal[]

  @@map("pipeline_stages")
}

model Deal {
  id        String   @id @default(cuid())
  contactId String
  stageId   String
  amount    Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assignedToId String?

  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stage       PipelineStage @relation(fields: [stageId], references: [id])
  assignedTo  User?         @relation(fields: [assignedToId], references: [id])

  @@map("deals")
}

model Template {
  id             String   @id @default(cuid())
  name           String
  category       String
  language       String   @default("pt_BR")
  components     Json
  waTemplateName String?
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("templates")
}

model Rule {
  id      String   @id @default(cuid())
  name    String
  when    Json
  then    Json
  enabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rules")
}
